# Google Sheets Web App Script URL (Deploy as a Web App in Google Apps Script and paste URL here)
GOOGLE_SHEETS_SCRIPT_URL=your_google_sheets_web_app_url_here

# Backend Server PORT configuration (default: 5000)
PORT=5000

# EmailJS Configuration
EMAILJS_SERVICE_ID=your_emailjs_service_id
EMAILJS_PUBLIC_KEY=your_emailjs_public_key
EMAILJS_PRIVATE_KEY=your_emailjs_private_key
EMAILJS_CONTACT_TEMPLATE_ID=your_emailjs_contact_template_id
EMAILJS_NEWSLETTER_TEMPLATE_ID=your_emailjs_newsletter_template_id

